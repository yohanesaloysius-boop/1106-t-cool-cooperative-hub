# ============================================
# CONTOH KONFIGURASI ENVIRONMENT (.env.example)
# ============================================
# Salin file ini menjadi .env lalu isi dengan nilai asli.
# JANGAN commit file .env ke repository.
#
# Catatan: Pada Lovable Cloud, file .env dikelola otomatis.
# Secret sensitif (service role key, dll) TIDAK disimpan di sini —
# gunakan fitur Secrets (Project Settings) untuk secret rahasia.

# --- Supabase / Lovable Cloud (publishable / aman untuk client) ---
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
